global:
  scrape_interval: 15s
  evaluation_interval: 15s

scrape_configs:
  - job_name: "prometheus"
    static_configs:
      - targets: ["localhost:9090"]

  - job_name: "instahelper-app"
    scrape_interval: 10s
    metrics_path: /metrics
    static_configs:
      - targets: ["34.173.127.14:8080"]

  - job_name: "app-server"
    scrape_interval: 10s
    static_configs:
      - targets: ["34.173.127.14:9100"]
